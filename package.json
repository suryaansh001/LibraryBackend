    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@fastify/websocket": "^8.3.1",
    "@sinclair/typebox": "^0.34.41",
